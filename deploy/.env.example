# Olisar server config. Copy to `.env` and fill in. Everything is read at startup;
# values you change later are best set in the dashboard (they persist in the volume).

# ── Required: your Discord application ───────────────────────────────────────
# Discord Developer Portal → your app → Bot (token) and OAuth2 (client id + secret).
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Your Discord user ID, so you can sign in to the console (comma-separated for several).
ADMIN_ALLOWLIST=
# Optional: your main server's ID (used for DMs). Leave blank to set up per-server later.
TARGET_GUILD_ID=

# ── Required: AI (free) ──────────────────────────────────────────────────────
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Public access via Tailscale Funnel ───────────────────────────────────────
# A reusable auth key: https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTH=
# Optional device name → https://<name>.<your-tailnet>.ts.net  (default: olisar)
OLISAR_FUNNEL_HOSTNAME=olisar

# ── Optional ─────────────────────────────────────────────────────────────────
# Image generation (FLUX). https://dash.cloudflare.com → account id + a Workers AI token.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Star Citizen extension (raises rate limits): https://uexcorp.uk/api
UEX_API_KEY=

# ── Leave as-is (set for the server image) ───────────────────────────────────
OLISAR_HEADLESS=1
# SESSION_SECRET is auto-generated and persisted in the data volume on first run —
# don't set it here (changing it logs everyone out).

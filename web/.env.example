# Leave VITE_API_BASE empty to use the same-origin Vite dev proxy (recommended —
# see vite.config.ts). The app then calls /api and /auth on its own origin and
# Vite forwards them to the FastAPI server on :8000, so the OAuth cookie/redirect
# flow "just works" with no CORS headaches.
#
# Only set this if you intentionally run the API on a different origin than the
# dashboard (e.g. a deployed API). Then point it at that origin:
# VITE_API_BASE=https://api.example.com
VITE_API_BASE=

# ─── Discord ──────────────────────────────────────────────────────────────
# From https://discord.com/developers/applications → your app
DISCORD_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-application-id
DISCORD_CLIENT_SECRET=your-oauth2-client-secret
# The single guild (server) Olisar serves. Right-click the server → Copy Server ID
# (requires Developer Mode enabled in Discord settings).
TARGET_GUILD_ID=000000000000000000

# ─── Gemini (Google AI Studio free tier) ─────────────────────────────────────
# Create a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Model assignment (free-tier defaults — see plan §6). Override only if needed.
GEMINI_CHAT_MODEL=gemini-flash-latest
GEMINI_LITE_MODEL=gemini-flash-lite-latest
GEMINI_EMBED_MODEL=gemini-embedding-001

# ─── Cloudflare Workers AI (image generation, free tier) ─────────────────────
# Powers the generate_image tool (Gemini's image models are paid-only). Leave
# blank to disable image generation. Workers AI gives a free daily allocation.
#   • Account ID:  Cloudflare dashboard → Workers & Pages (right sidebar), or the
#                  hex string in the dashboard URL after /accounts/.
#   • API token:   My Profile → API Tokens → Create Token → "Workers AI" template
#                  (needs the "Workers AI: Read" permission). Keep the free plan
#                  to avoid charges past the daily allocation.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Optional override; FLUX.1 [schnell] is fast and free-tier friendly.
CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell

# ─── Star Citizen extension (optional) ───────────────────────────────────────
# UEX (uexcorp.space) bearer token for the UEX tools. OPTIONAL — most UEX read
# endpoints are public; a token raises rate limits / unlocks some. Create one at
# https://uexcorp.space/api/apps. Leave blank to use the public endpoints.
UEX_API_KEY=

# ─── Admin dashboard auth ────────────────────────────────────────────────────
# Comma-separated Discord user IDs always allowed into the dashboard.
# (Users with Manage Server in TARGET_GUILD_ID are also admitted automatically.)
ADMIN_ALLOWLIST=000000000000000000
# Random secret for signing session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me-to-a-long-random-string
# Public HTTPS origin (the Cloudflare Tunnel hostname). Used to build the OAuth
# redirect URI, which must EXACTLY match what you register in the Discord portal.
PUBLIC_BASE_URL=https://olisar.example.com

# ─── Local services ──────────────────────────────────────────────────────────
DATABASE_PATH=data/olisar.db
API_HOST=127.0.0.1
API_PORT=8000
# Loopback-only control endpoint the API uses to push live config reloads to the bot.
CONTROL_HOST=127.0.0.1
CONTROL_PORT=8765
